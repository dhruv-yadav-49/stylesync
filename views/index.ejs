<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>StyleSync | Living Design Systems</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="icon" href="https://fav.farm/✨">
</head>
<body>
  <main class="hero">
    <div class="hero-content">
      <h1 class="logo-main">StyleSync</h1>
      <p>Transform any website into an interactive, living design system. Analyze colors, typography, and spacing tokens in seconds with AI-driven extraction.</p>
      
      <form id="scrape-form" class="search-container">
        <input type="url" name="url" class="search-input" placeholder="Paste website URL (e.g., https://apple.com)" required>
        <button type="submit" class="search-btn">Analyze Site</button>
      </form>

      <!-- Parsing Visualization -->
      <div id="loader" class="parsing-overlay">
        <div class="parsing-loader"></div>
        <div class="parsing-text">Analyzing Architectural Patterns...</div>
        <div id="parsing-status" style="margin-top: 1.5rem; color: var(--app-text-muted); font-size: 0.9rem; font-family: 'Inter', sans-serif;">Deep scanning DOM tree & computed styles</div>
      </div>

      <!-- Skeleton Screen -->
      <div id="skeleton" class="skeleton-container" style="display: none; margin: 4rem auto;">
        <div class="skeleton" style="width: 100%; height: 60px; margin-bottom: 2rem;"></div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; width: 100%;">
          <div class="skeleton" style="height: 300px;"></div>
          <div class="skeleton" style="height: 300px;"></div>
        </div>
      </div>
    </div>
    
    <div id="error-msg" class="glass-card" style="display: none; color: #ef4444; margin-top: 2rem; padding: 1rem 2rem;"></div>
  </main>

  <script src="/js/index.js"></script>
</body>
</html>
