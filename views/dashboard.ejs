<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>StyleSync Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <style id="dynamic-theme">
    /* Initial Theme injected via JS */
  </style>
</head>
<body>
  <div class="dashboard">
    <!-- Sidebar / Token Editor -->
    <aside class="sidebar">
      <div class="sidebar-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h2>Token Editor</h2>
        <a href="/" class="exit-link" style="color: var(--app-text-muted); text-decoration: none; font-size: 0.8rem;">← Exit</a>
      </div>

      <div id="site-info" class="glass-card" style="padding: 1.25rem;">
        <p id="site-name" style="font-weight: 600; color: #fff;"></p>
        <p id="site-url" style="font-size: 0.75rem; word-break: break-all; margin-top: 0.25rem;"></p>
      </div>

      <div class="token-group">
        <h3>Colors</h3>
        <div id="color-tokens">
          <!-- Swatches injected via JS -->
        </div>
      </div>

      <div class="token-group">
        <h3>Typography</h3>
        <div id="typography-tokens">
          <!-- Enhanced Typography Inspector injected via JS -->
        </div>
      </div>

      <div class="token-group">
        <h3>Spacing Scale</h3>
        <div id="spacing-tokens">
          <!-- Spacing Visualizer injected via JS -->
        </div>
        <div id="spacing-bars" class="spacing-visualizer">
          <!-- Interactive scale bars -->
        </div>
      </div>

      <div class="token-group">
        <h3>Time Machine</h3>
        <div id="version-history" class="history-list">
          <!-- Versions injected via JS -->
          <p style="font-size: 0.75rem; opacity: 0.5;">No history available yet.</p>
        </div>
      </div>

      <div class="sidebar-footer" style="margin-top: auto;">
        <button id="save-btn" class="search-btn" style="width: 100%;">Save Changes</button>
        <div id="export-options" style="margin-top: 1rem; display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem;">
          <button onclick="exportTokens('css')" class="glass-card" style="padding: 0.75rem; cursor: pointer; color: #fff; font-size: 0.7rem;">Export CSS</button>
          <button onclick="exportTokens('json')" class="glass-card" style="padding: 0.75rem; cursor: pointer; color: #fff; font-size: 0.7rem;">Export JSON</button>
          <button onclick="exportTokens('tailwind')" class="glass-card" style="padding: 0.75rem; cursor: pointer; color: #fff; font-size: 0.7rem; grid-column: span 2;">Export Tailwind Config</button>
        </div>
      </div>
    </aside>

    <!-- Main Content / Preview Grid -->
    <main class="main-content">
      <header style="margin-bottom: 4rem;">
        <h1 style="font-size: 3.5rem; margin-bottom: 0.5rem; letter-spacing: -0.04em;">Component Preview</h1>
        <p style="font-size: 1.1rem; opacity: 0.8;">A professional UI kit that instantly adapts to your branding.</p>
      </header>

      <section class="specimen-grid">
        <!-- Buttons Specimen -->
        <div class="card-specimen">
          <h4 style="margin-bottom: 2rem;">Buttons</h4>
          <div style="display: flex; gap: 1.5rem; flex-wrap: wrap; align-items: center;">
            <button class="btn-primary-preview" style="padding: 1rem 2.25rem; border: none; border-radius: var(--ui-radius); background: var(--ui-primary); color: #fff; font-weight: 600; font-family: var(--ui-body-font); cursor: pointer; transition: var(--transition);">Primary Action</button>
            <button class="btn-secondary-preview" style="padding: 1rem 2.25rem; border: 2px solid var(--ui-secondary); border-radius: var(--ui-radius); background: transparent; color: var(--ui-secondary); font-weight: 600; font-family: var(--ui-body-font); cursor: pointer; transition: var(--transition);">Secondary</button>
            <button class="btn-ghost-preview" style="padding: 1rem 2.25rem; border: none; border-radius: var(--ui-radius); background: transparent; color: var(--ui-text); opacity: 0.6; font-weight: 600; font-family: var(--ui-body-font); cursor: pointer; transition: var(--transition);">Ghost Link</button>
          </div>
        </div>

        <!-- Inputs Specimen -->
        <div class="card-specimen">
          <h4 style="margin-bottom: 2rem;">Form Elements</h4>
          <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label style="font-size: 0.8rem; font-weight: 500; opacity: 0.7;">Default Input</label>
              <input type="text" placeholder="Entry field..." style="padding: 1rem; background: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); border-radius: var(--ui-radius); width: 100%; font-family: var(--ui-body-font); color: var(--ui-text);">
            </div>
            <div style="display: flex; flex-direction: column; gap: 0.5rem;">
              <label style="font-size: 0.8rem; font-weight: 500; opacity: 0.7; color: var(--ui-primary);">Focused State</label>
              <input type="text" placeholder="Active input..." style="padding: 1rem; background: rgba(0,0,0,0.2); border: 2px solid var(--ui-primary); border-radius: var(--ui-radius); width: 100%; outline: none; font-family: var(--ui-body-font); color: var(--ui-text); box-shadow: 0 0 15px var(--app-accent-glow);">
            </div>
          </div>
        </div>

        <!-- Card Variations -->
        <div class="card-specimen" style="grid-column: 1 / -1;">
          <h4 style="margin-bottom: 2rem;">Card Surface Variations</h4>
          <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem;">
            <!-- Elevated Card -->
            <div style="padding: 2rem; background: var(--ui-bg); border-radius: var(--ui-radius); border: 1px solid rgba(255,255,255,0.05); box-shadow: 0 20px 40px rgba(0,0,0,0.4);">
               <h5 style="margin-bottom: 0.75rem; color: var(--ui-text);">Elevated Card</h5>
               <p style="font-size: 0.9rem; opacity: 0.7; font-family: var(--ui-body-font);">Strong shadow and subtle border for premium depth.</p>
            </div>
            <!-- Soft Card -->
            <div style="padding: 2rem; background: rgba(255,255,255,0.02); border-radius: var(--ui-radius); border: 1px solid rgba(255,255,255,0.1);">
               <h5 style="margin-bottom: 0.75rem; color: var(--ui-text);">Soft Outline</h5>
               <p style="font-size: 0.9rem; opacity: 0.7; font-family: var(--ui-body-font);">Modern flat design with emphasis on the border stroke.</p>
            </div>
            <!-- Accent Card -->
            <div style="padding: 2rem; background: var(--ui-primary); border-radius: var(--ui-radius); color: #fff;">
               <h5 style="margin-bottom: 0.75rem; color: #fff;">Branded Surface</h5>
               <p style="font-size: 0.9rem; opacity: 0.9; font-family: var(--ui-body-font);">High-energy state using the primary brand color.</p>
            </div>
          </div>
        </div>

        <!-- Typography Scale -->
        <div class="card-specimen" style="grid-column: 1 / -1;">
          <h4 style="margin-bottom: 2rem;">Typography Hierarchy</h4>
          <div style="display: flex; flex-direction: column; gap: 2.5rem;">
            <div>
               <h1 style="font-family: var(--ui-heading-font); color: var(--ui-text); font-size: var(--ui-h1); line-height: 1.15; margin-bottom: 0.5rem; letter-spacing: -0.02em;">Digital Craftsmanship</h1>
               <p id="h1-label" style="font-size: 0.8rem; opacity: 0.5; font-family: var(--ui-body-font); text-transform: uppercase; letter-spacing: 0.05em;">Display H1 • 3.5rem</p>
            </div>
            <div>
               <h2 style="font-family: var(--ui-heading-font); color: var(--ui-text); font-size: var(--ui-h2); line-height: 1.25; margin-bottom: 0.5rem;">Subheadings and Section Titles</h2>
               <p style="font-size: 0.8rem; opacity: 0.5; font-family: var(--ui-body-font); text-transform: uppercase;">Header H2 • 2rem</p>
            </div>
            <div>
               <p style="font-family: var(--ui-body-font); color: var(--ui-text); font-size: var(--ui-body-size); line-height: 1.75; max-width: 850px;">
                 Design is not just what it looks like and feels like. Design is how it works. This body text demonstrates the legibility and character of your chosen body typeface. 
                 It should be comfortable to read over long periods while maintaining brand personality and accessible contrast ratios.
               </p>
               <p style="font-size: 0.8rem; opacity: 0.5; font-family: var(--ui-body-font); margin-top: 1rem;">Body Copy • 1rem</p>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>

  <script src="/js/dashboard.js"></script>
</body>
</html>
